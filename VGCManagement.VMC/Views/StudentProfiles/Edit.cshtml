@model VGCManagement.DOMAIN.StudentProfile

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h2 class="fw-bold text-dark mb-0">Update Profile</h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-bold text-muted small text-uppercase">Student Name</label>
                            <input asp-for="FullName" class="form-control form-control-lg border-2 shadow-none" />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StudentNumber" class="form-label fw-bold text-muted small text-uppercase">ID Number</label>
                                <input asp-for="StudentNumber" class="form-control border-2 shadow-none" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-bold text-muted small text-uppercase">Email</label>
                                <input asp-for="Email" class="form-control border-2 shadow-none" />
                            </div>
                        </div>
                        <div class="d-flex gap-3 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm">Update Information</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>