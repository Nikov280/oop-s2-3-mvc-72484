@model VGCManagement.DOMAIN.StudentProfile

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-3 py-5 px-4">
                <div class="mb-4">
                    <i class="bi bi-person-x-fill text-danger display-1"></i>
                </div>
                <h2 class="fw-bold mb-3 text-dark">Remove Student?</h2>
                <p class="text-muted mb-4">
                    Warning: You are about to remove <strong>@Model.FullName</strong> from the system. This will affect their enrollments and academic history.
                </p>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2 px-md-5">
                        <button type="submit" class="btn btn-danger btn-lg shadow-sm">Delete Permanently</button>
                        <a asp-action="Index" class="btn btn-link text-secondary">Cancel and Keep</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>