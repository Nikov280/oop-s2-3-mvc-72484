@model VGCManagement.DOMAIN.StudentProfile

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                <div class="bg-primary p-5 text-center text-white">
                    <div class="bg-white bg-opacity-25 d-inline-block p-4 rounded-circle mb-3">
                        <i class="bi bi-person-badge fs-1"></i>
                    </div>
                    <h2 class="fw-bold">@Model.FullName</h2>
                    <p class="mb-0 opacity-75">Student ID: @Model.StudentNumber</p>
                </div>
                <div class="card-body p-5">
                    <div class="row text-center g-4">
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <label class="text-muted small text-uppercase fw-bold d-block">Email Address</label>
                                <span class="fs-5">@Model.Email</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <label class="text-muted small text-uppercase fw-bold d-block">Status</label>
                                <span class="badge bg-success px-3 py-2 mt-1">Active Account</span>
                            </div>
                        </div>
                    </div>
                    <div class="mt-5 d-flex justify-content-center gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4">Edit Profile</a>
                        <a asp-action="Index" class="btn btn-light px-4">Back to Registry</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>