@model IEnumerable<VGCManagement.DOMAIN.Exam>

@{
    ViewData["Title"] = "Manage Exams";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Manage Exams</h1>
        <p>
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle"></i> Create New Exam
            </a>
        </p>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Course</th>
                        <th>Exam Title</th>
                        <th class="text-center">Date</th>
                        <th class="text-center">Status</th> 
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 align-middle">
                                <span class="text-muted small">Course:</span><br />
                                <span class="fw-bold">@(item.Course?.Name ?? "N/A")</span>
                            </td>
                            <td class="align-middle">
                                <span class="badge bg-light text-dark border">@item.Title</span>
                            </td>
                            <td class="text-center align-middle">
                                @item.Date.ToString("dd/MM/yyyy")
                            </td>
                            <td class="text-center align-middle">
                                @if (item.ResultsReleased)
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-circle"></i> Published
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-clock"></i> Pending
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4 align-middle">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary">Details</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    
    .card {
        border-radius: 12px;
        border: none;
    }

    .table thead th {
        border-top: none;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        padding: 15px 10px;
    }

    .badge {
        font-size: 0.85em;
        padding: 0.5em 0.8em;
        border-radius: 6px;
    }

    .btn-group-sm > .btn {
        padding: 0.4rem 0.8rem;
    }
</style>