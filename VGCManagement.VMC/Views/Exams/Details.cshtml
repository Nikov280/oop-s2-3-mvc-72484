@model VGCManagement.DOMAIN.Exam

@{
    ViewData["Title"] = "Exam Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0">Exam Specification</h4>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="display-6 fw-bold">@Model.Title</div>
                        <span class="badge @(Model.ResultsReleased ? "bg-success" : "bg-warning text-dark") mt-2">
                            @(Model.ResultsReleased ? "Results Published" : "Results Pending")
                        </span>
                    </div>

                    <div class="list-group list-group-flush mb-4">
                        <div class="list-group-item d-flex align-items-center py-3">
                            <i class="bi bi-book text-primary me-3" style="font-size: 1.5rem;"></i>
                            <div>
                                <div class="text-muted small">Course</div>
                                <div class="fw-bold">@(Model.Course?.Name ?? "N/A")</div>
                            </div>
                        </div>
                        <div class="list-group-item d-flex align-items-center py-3">
                            <i class="bi bi-calendar-event text-primary me-3" style="font-size: 1.5rem;"></i>
                            <div>
                                <div class="text-muted small">Date</div>
                                <div class="fw-bold">@Model.Date.ToString("dddd, dd MMMM yyyy")</div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4">Edit Exam</a>
                        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>