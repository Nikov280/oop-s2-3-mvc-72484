@model IEnumerable<VGCManagement.DOMAIN.ExamResult>

@{
    ViewData["Title"] = "Gradebook";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gradebook</h1>
        @if (!User.IsInRole("Student"))
        {
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                Add New Result
            </a>
        }
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Exam Title</th>
                        <th>Student</th>
                        <th class="text-center">Score</th>
                        <th class="text-center">Status</th> @* Cambiado de Grade a Status *@
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 align-middle fw-bold">
                                @(item.Exam?.Title ?? "N/A")
                            </td>
                            <td class="align-middle">
                                @(item.Student?.FullName ?? "N/A")
                            </td>
                            <td class="text-center align-middle">
                                <span class="badge bg-light text-dark border">@item.Score</span>
                            </td>
                            <td class="text-center align-middle">
                                @if (item.Score >= 40)
                                {
                                    <span class="badge bg-success">Passed</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Failed</span>
                                }
                            </td>
                            <td class="text-end pe-4 align-middle">
                                <div class="btn-group btn-group-sm">
                                    @if (!User.IsInRole("Student"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">Edit</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Delete</a>
                                    }
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary">Details</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .badge {
        min-width: 70px;
        padding: 0.5em 0.7em;
    }
</style>