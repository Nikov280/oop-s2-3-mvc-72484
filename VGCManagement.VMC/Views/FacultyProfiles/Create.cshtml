@model VGCManagement.DOMAIN.FacultyProfile

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-0 pt-4 px-4 text-center">
                    <h2 class="fw-bold text-dark mb-0">Faculty Registration</h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-muted small text-uppercase">Full Name</label>
                            <input asp-for="Name" class="form-control form-control-lg border-2 shadow-none" placeholder="Professor Name" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="EmployeeNumber" class="form-label fw-bold text-muted small text-uppercase">Faculty ID #</label>
                                <input asp-for="EmployeeNumber" class="form-control border-2 shadow-none" placeholder="FAC-000" />
                                <span asp-validation-for="EmployeeNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-bold text-muted small text-uppercase">Email Address</label>
                                <input asp-for="Email" type="email" class="form-control border-2 shadow-none" placeholder="name@vgc.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 pt-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">Save Faculty Member</button>
                            <a asp-action="Index" class="btn btn-link text-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>