@model VGCManagement.DOMAIN.FacultyProfile

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h2 class="fw-bold text-dark mb-0">Edit Faculty Profile</h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold text-muted small text-uppercase">Name</label>
                            <input asp-for="Name" class="form-control form-control-lg border-2 shadow-none" />
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="EmployeeNumber" class="form-label fw-bold text-muted small text-uppercase">Faculty ID</label>
                                <input asp-for="EmployeeNumber" class="form-control border-2 shadow-none" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-bold text-muted small text-uppercase">Email</label>
                                <input asp-for="Email" class="form-control border-2 shadow-none" />
                            </div>
                        </div>
                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm">Update</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>