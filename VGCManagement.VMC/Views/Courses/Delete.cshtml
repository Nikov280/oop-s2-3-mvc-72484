@model VGCManagement.DOMAIN.Course

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-3 py-4">
                <div class="card-body">
                    <div class="mb-4">
                        <i class="bi bi-exclamation-triangle-fill text-danger display-1"></i>
                    </div>
                    <h2 class="fw-bold mb-3">Delete Course?</h2>
                    <p class="text-muted mb-4 px-4">
                        You are about to permanently remove <strong>@Model.Name</strong>. This action cannot be undone and may affect enrolled students.
                    </p>
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2 px-4">
                            <button type="submit" class="btn btn-danger btn-lg">Confirm Deletion</button>
                            <a asp-action="Index" class="btn btn-link text-secondary">No, Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>