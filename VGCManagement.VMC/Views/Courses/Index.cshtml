@model IEnumerable<VGCManagement.DOMAIN.Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h1 class="fw-bold mb-0">Courses</h1>
            <p class="text-muted">Manage academic programs and schedules</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm px-4">
            <i class="bi bi-plus-lg"></i> Create New Course
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-muted">Course Details</th>
                        <th class="py-3 text-muted">Branch</th>
                        <th class="py-3 text-muted">Timeline</th>
                        <th class="pe-4 py-3 text-end text-muted">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-4">
                                <span class="d-block fw-bold fs-5 text-dark">@item.Name</span>
                                <span class="text-muted small">ID: #@item.Id.ToString("D3")</span>
                            </td>
                            <td>
                                <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle px-3 py-2 rounded-pill">
                                    <i class="bi bi-geo-alt"></i> @(item.Branch?.Name ?? "Main Branch")
                                </span>
                            </td>
                            <td>
                                <div class="small fw-semibold text-dark">@item.StartDate.ToShortDateString()</div>
                                <div class="small text-muted">to @item.EndDate.ToShortDateString()</div>
                            </td>
                            <td class="pe-4 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm px-3">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm px-3">
                                        <i class="bi bi-eye"></i> Details
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm px-3">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-sm {
        padding: 0.5rem 0.8rem;
        font-weight: 500;
    }

    .bg-info-subtle {
        background-color: #e0f7fa !important;
        color: #006064 !important;
    }
</style>