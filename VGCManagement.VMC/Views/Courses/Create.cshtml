@model VGCManagement.DOMAIN.Course

@{
    ViewData["Title"] = "Create Course";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3">
                            <i class="bi bi-journal-plus text-primary fs-4"></i>
                        </div>
                        <h2 class="fw-bold text-dark mb-0">New Course</h2>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-muted small text-uppercase">Course Designation</label>
                            <input asp-for="Name" class="form-control form-control-lg border-2 shadow-none" placeholder="e.g. Bachelor of Computer Science" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-12">
                                <label asp-for="BranchId" class="form-label fw-bold text-muted small text-uppercase">Assign to Branch</label>
                                <select asp-for="BranchId" class="form-select border-2 shadow-none" asp-items="ViewBag.BranchId">
                                    <option value="">-- Select a Location --</option>
                                </select>
                                <span asp-validation-for="BranchId" class="text-danger small"></span>
                            </div>
                        </div>

                        
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="StartDate" class="form-label fw-bold text-muted small text-uppercase">Start Date</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-2 border-end-0 text-muted">
                                        <i class="bi bi-calendar-plus"></i>
                                    </span>
                                    <input asp-for="StartDate" type="date" class="form-control border-2 border-start-0 shadow-none" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                </div>
                                <span asp-validation-for="StartDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EndDate" class="form-label fw-bold text-muted small text-uppercase">End Date</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-2 border-end-0 text-muted">
                                        <i class="bi bi-calendar-check"></i>
                                    </span>
                                    <input asp-for="EndDate" type="date" class="form-control border-2 border-start-0 shadow-none" value="@DateTime.Now.AddMonths(4).ToString("yyyy-MM-dd")" />
                                </div>
                                <span asp-validation-for="EndDate" class="text-danger small"></span>
                            </div>
                        </div>

                        
                        <hr class="my-4 opacity-25">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                <i class="bi bi-plus-circle me-1"></i> Create Course
                            </button>
                            <a asp-action="Index" class="btn btn-link text-secondary">
                                Cancel and Return
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f3f6f9;
    }

    .form-control, .form-select {
        border-color: #e9ecef;
        border-radius: 8px;
        transition: all 0.2s;
    }

        .form-control:focus, .form-select:focus {
            border-color: #0d6efd;
            background-color: #fff;
        }

    .btn-lg {
        font-size: 1rem;
        font-weight: 600;
        padding: 0.8rem;
    }

    .input-group-text {
        border-color: #e9ecef;
        border-radius: 8px;
    }
</style>