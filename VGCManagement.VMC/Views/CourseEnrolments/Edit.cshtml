@model VGCManagement.DOMAIN.CourseEnrolment

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-0 pt-4 px-4 text-center">
                    <h2 class="fw-bold text-dark mb-0">Modify Enrollment</h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase">Student</label>
                            <select asp-for="StudentProfileId" class="form-select border-2" asp-items="ViewBag.StudentProfileId"></select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase">Course</label>
                            <select asp-for="CourseId" class="form-select border-2" asp-items="ViewBag.CourseId"></select>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm">Save Changes</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>