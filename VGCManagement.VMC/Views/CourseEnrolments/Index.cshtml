@model IEnumerable<VGCManagement.DOMAIN.CourseEnrolment>

@{
    ViewData["Title"] = "Enrollments";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h1 class="fw-bold mb-0">Course Enrollments</h1>
            <p class="text-muted">Manage student assignments to academic courses</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm px-4">
            <i class="bi bi-link-45deg"></i> New Enrollment
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-muted">Student</th>
                        <th class="py-3 text-muted">Assigned Course</th>
                        <th class="py-3 text-muted">Enrollment Date</th>
                        <th class="pe-4 py-3 text-end text-muted">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-4">
                                <div class="fw-bold text-dark">@(item.StudentProfile?.FullName ?? "N/A")</div>
                                <div class="text-muted small">ID: @item.StudentProfile?.StudentNumber</div>
                            </td>
                            <td>
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2 rounded-2">
                                    <i class="bi bi-book me-1"></i> @(item.Course?.Name ?? "N/A")
                                </span>
                            </td>
                            <td>
                                <div class="text-muted small">
                                    <i class="bi bi-calendar3 me-1"></i> Registered on system
                                </div>
                            </td>
                            <td class="pe-4 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm px-3">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm px-3">
                                        <i class="bi bi-eye"></i> Details
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm px-3">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>