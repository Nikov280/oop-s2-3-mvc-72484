@model VGCManagement.DOMAIN.CourseEnrolment

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-3 py-5 px-4">
                <div class="mb-4">
                    <i class="bi bi-link-45deg text-danger display-1" style="filter: drop-shadow(0 0 10px rgba(220, 53, 69, 0.2));"></i>
                </div>
                <h2 class="fw-bold mb-3 text-dark">Unenroll Student?</h2>
                <p class="text-muted mb-4">
                    You are about to remove <strong>@Model.StudentProfile?.FullName</strong> from the course <strong>@Model.Course?.Name</strong>.
                </p>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2 px-md-5">
                        <button type="submit" class="btn btn-danger btn-lg shadow-sm fw-bold">Confirm Unenrollment</button>
                        <a asp-action="Index" class="btn btn-link text-secondary">Keep Enrollment</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>