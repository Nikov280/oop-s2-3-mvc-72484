@model VGCManagement.DOMAIN.CourseEnrolment

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                <div class="card-header bg-primary text-white p-4 text-center">
                    <h4 class="mb-0 fw-bold">Enrollment Summary</h4>
                </div>
                <div class="card-body p-5">
                    <div class="row align-items-center mb-4">
                        <div class="col-5 text-end">
                            <div class="fw-bold fs-5">@Model.StudentProfile?.FullName</div>
                            <div class="text-muted small">Student</div>
                        </div>
                        <div class="col-2 text-center text-primary">
                            <i class="bi bi-arrow-left-right fs-3"></i>
                        </div>
                        <div class="col-5 text-start">
                            <div class="fw-bold fs-5">@Model.Course?.Name</div>
                            <div class="text-muted small">Course</div>
                        </div>
                    </div>

                    <div class="bg-light p-3 rounded-3 text-center mb-4">
                        <span class="text-muted small fw-bold text-uppercase">Enrollment Status:</span>
                        <span class="text-success ms-2 fw-bold"><i class="bi bi-check-circle-fill"></i> Active</span>
                    </div>

                    <div class="d-flex justify-content-center gap-2 mt-4">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4">Edit</a>
                        <a asp-action="Index" class="btn btn-light px-4">Back</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>