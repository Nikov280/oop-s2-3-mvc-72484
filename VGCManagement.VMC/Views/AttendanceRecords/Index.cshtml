@model IEnumerable<VGCManagement.DOMAIN.AttendanceRecord>

@{
    ViewData["Title"] = "Attendance Tracking";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Attendance Tracking</h1>
        @if (!User.IsInRole("Student"))
        {
            <p>
                <a asp-action="Create" class="btn btn-primary shadow-sm">
                    <i class="bi bi-person-plus"></i> Add New Record
                </a>
            </p>
        }
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Student Info</th>
                        <th>Course</th>
                        <th class="text-center">Week</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 align-middle">
                                <div class="fw-bold">@(item.CourseEnrolment?.StudentProfile?.FullName ?? "N/A")</div>
                                <div class="text-muted small">ID: @(item.CourseEnrolment?.StudentProfile?.StudentNumber ?? "N/A")</div>
                            </td>
                            <td class="align-middle">
                                <span class="text-truncate d-inline-block" style="max-width: 200px;">
                                    @(item.CourseEnrolment?.Course?.Name ?? "N/A")
                                </span>
                            </td>
                            <td class="text-center align-middle">
                                <span class="badge bg-light text-dark border">Week @item.WeekNumber</span>
                            </td>
                            <td class="text-center align-middle">
                                @if (item.Present)
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-lg"></i> Present
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        <i class="bi bi-x-lg"></i> Absent
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4 align-middle">
                                <div class="btn-group btn-group-sm">
                                    @if (!User.IsInRole("Student"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">Edit</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Delete</a>
                                    }
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary">Details</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    
    .card {
        border-radius: 12px;
        border: none;
    }

    .table thead th {
        border-top: none;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        padding: 15px 10px;
    }

    .badge {
        font-size: 0.85em;
        padding: 0.5em 0.8em;
        min-width: 85px;
    }

    .btn-group-sm > .btn {
        padding: 0.4rem 0.8rem;
    }
    
    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.04);
    }
</style>