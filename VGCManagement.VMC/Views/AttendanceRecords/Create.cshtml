@model VGCManagement.DOMAIN.AttendanceRecord

@{
    ViewData["Title"] = "Record Attendance";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-0 pt-4 px-4 text-center">
                    <div class="bg-success bg-opacity-10 d-inline-block p-3 rounded-circle mb-2">
                        <i class="bi bi-calendar-check text-success fs-3"></i>
                    </div>
                    <h2 class="fw-bold text-dark mb-0">Record Attendance</h2>
                    <p class="text-muted small text-uppercase fw-bold mt-2">New Entry</p>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="CourseEnrolmentId" class="form-label fw-bold text-muted small text-uppercase">Student & Course</label>
                            <select asp-for="CourseEnrolmentId" class="form-select form-select-lg border-2 shadow-none" asp-items="ViewBag.CourseEnrolmentId">
                                <option value="">-- Select Enrollment --</option>
                            </select>
                            <span asp-validation-for="CourseEnrolmentId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="WeekNumber" class="form-label fw-bold text-muted small text-uppercase">Week Number</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-2 border-end-0 text-muted">
                                    <i class="bi bi-hash"></i>
                                </span>
                                <input asp-for="WeekNumber" type="number" min="1" max="52" class="form-control border-2 border-start-0 shadow-none" placeholder="1-52" />
                            </div>
                            <span asp-validation-for="WeekNumber" class="text-danger small"></span>
                        </div>

                        <div class="form-check form-switch mb-4 p-3 bg-light rounded-3 ms-0 d-flex justify-content-between align-items-center">
                            <label class="form-check-label fw-bold text-dark ms-2" for="presentSwitch">Is Student Present?</label>
                            <input class="form-check-input ms-0" type="checkbox" asp-for="Present" id="presentSwitch" checked style="width: 3em; height: 1.5em;">
                        </div>

                        <hr class="my-4 opacity-25">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm fw-bold">
                                <i class="bi bi-check-circle me-1"></i> Confirm Attendance
                            </button>
                            <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none">
                                Cancel and return
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}