@model VGCManagement.DOMAIN.AttendanceRecord

@{
    ViewData["Title"] = "Delete Record";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow-sm">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0">Confirm Deletion</h4>
                </div>
                <div class="card-body p-4 text-center">
                    <i class="bi bi-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
                    <p class="lead mt-3">Are you sure you want to delete this record?</p>
                    <div class="bg-light p-3 rounded mb-4">
                        <strong>@Model.CourseEnrolment?.StudentProfile?.FullName</strong><br />
                        <span class="text-muted">Week @Model.WeekNumber - @Model.CourseEnrolment?.Course?.Name</span>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger">Yes, Delete Record</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">No, Keep Record</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>