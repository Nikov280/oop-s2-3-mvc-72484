@model VGCManagement.DOMAIN.AttendanceRecord

@{
    ViewData["Title"] = "Record Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">Record Details</h4>
                    <span class="badge @(Model.Present ? "bg-success" : "bg-danger")">
                        @(Model.Present ? "Present" : "Absent")
                    </span>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Student Name</div>
                        <div class="col-sm-8 fw-bold">@(Model.CourseEnrolment?.StudentProfile?.FullName ?? "N/A")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Course</div>
                        <div class="col-sm-8">@(Model.CourseEnrolment?.Course?.Name ?? "N/A")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Week</div>
                        <div class="col-sm-8">Week @Model.WeekNumber</div>
                    </div>

                    <hr />

                    <div class="d-flex gap-2">
                        @if (!User.IsInRole("Student"))
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
                        }
                        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>