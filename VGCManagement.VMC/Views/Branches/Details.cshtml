@model VGCManagement.DOMAIN.Branch

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="bg-primary bg-opacity-10 d-inline-block p-4 rounded-circle mb-3">
                            <i class="bi bi-building fs-1 text-primary"></i>
                        </div>
                        <h2 class="fw-bold">@Model.Name</h2>
                        <p class="text-muted">Branch Reference #@Model.Id</p>
                    </div>

                    <div class="bg-light p-4 rounded-3 mb-4 text-center">
                        <label class="text-muted small text-uppercase fw-bold d-block mb-2">Primary Location</label>
                        <p class="fs-5 mb-0">@Model.Address</p>
                    </div>

                    <div class="d-flex justify-content-center gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4">Edit Branch</a>
                        <a asp-action="Index" class="btn btn-light px-4">Back to List</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>