@model VGCManagement.DOMAIN.Branch

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h2 class="fw-bold text-dark mb-0">Edit Branch</h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-muted small text-uppercase">Branch Name</label>
                            <input asp-for="Name" class="form-control form-control-lg border-2 shadow-none" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Address" class="form-label fw-bold text-muted small text-uppercase">Physical Address</label>
                            <textarea asp-for="Address" class="form-control border-2 shadow-none" rows="3"></textarea>
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>
                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm">Save Changes</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>